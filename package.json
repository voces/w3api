{
  "name": "w3api",
  "version": "3.0.0",
  "description": "TypeScript API for Warcraft III natives",
  "author": "verit",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json && ts-node bin/build.ts --unhandled-rejections=strict",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run test-lint && npm test",
    "test-debug": "node --experimental-vm-modules --inspect-brk node_modules/.bin/jest --runInBand",
    "test-lint": "deno lint . --ignore=node_modules,dist --rules-exclude=no-node-globals && deno fmt --check . --ignore=node_modules,dist",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/luaparse": "^0.2.13",
    "@types/node": "^24.12.4",
    "fast-glob": "^3.3.3",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voces/w3api.git"
  },
  "bugs": {
    "url": "https://github.com/voces/w3api/issues"
  },
  "homepage": "https://github.com/voces/w3api#readme",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "luaparse": "^0.3.1",
    "w3xdata": "^2.2.2"
  }
}
