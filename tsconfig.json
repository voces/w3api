{
  "compilerOptions": {
    "outDir": "dist",
    "allowJs": false,
    "target": "es2020",
    "lib": ["es2020", "dom"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "isolatedModules": true,
    "strict": true,
    "declaration": true,
    "types": ["@types/jest", "@types/node"],
    "esModuleInterop": true,
    "inlineSourceMap": true
  },
  "include": ["src", "bin"]
}
